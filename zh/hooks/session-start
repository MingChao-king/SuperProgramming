#!/usr/bin/env bash
# SessionStart hook for SuperProgramming plugin
# Injects a lightweight bootstrap. Project-specific information lives in
# the plugin's knowledge-base (roadmap), not in project files.
# User-level CLAUDE.md is auto-loaded by Claude Code.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# Lightweight bootstrap — ~500 tokens.
# The full methodology lives in:
#   1. Plugin knowledge-base (PLUGIN_ROOT/knowledge-base/)
#   2. L2: 通用编码经验.md (cross-project patterns)
#   3. Individual skill files (loaded via Skill tool on demand)
# Project-specific info (design, interfaces, progress) lives in
# knowledge-base/{project-name}/{project-name}-roadmap.md — NOT in project files.
bootstrap=$(cat <<'BOOTSTRAP'
<EXTREMELY-IMPORTANT>
You are powered by **SuperProgramming** — structured development with a four-level cache knowledge system.

## FIRST: Check project roadmap
If this project uses SuperProgramming, its roadmap is at:
`__PLUGIN_ROOT__/knowledge-base/{project-name}/{project-name}-roadmap.md`
This is the single source of truth for design, interfaces, and progress.
Project files contain ONLY the project itself — no SuperProgramming artifacts.

## Skill Discovery
Use the `Skill` tool with these exact names. **Never read skill files manually.**

| Skill | When | Type |
|-------|------|------|
| `superprogramming:brainstorming` | Before any coding task | Flexible |
| `superprogramming:writing-plans` | After design is approved | Flexible |
| `superprogramming:implementing` | During implementation (TDD → review → test) | **Rigid** |
| `superprogramming:closing-the-loop` | After all tasks complete | **Rigid** |
| `superprogramming:hotfix` | User explicitly invokes `skill:hotfix` | Flexible |

## Workflow
```
brainstorming → writing-plans → implementing(逐功能: TDD→审查→测试) → closing-the-loop
                                                                           ↑
                                                         hotfix ──────────┘
```

## Hard Gates
- If ANY SuperProgramming skill has ≥1% applicability to what you're doing, you MUST call it.
  This is non-negotiable. "Simple", "quick", "just one line" is not an excuse to skip skills.
- User instructions ALWAYS override skill instructions. The user controls the workflow.
- "I remember this skill" → Skills evolve. Load the current version via the Skill tool.
</EXTREMELY-IMPORTANT>
BOOTSTRAP
)

# Replace placeholder with actual plugin root path
bootstrap="${bootstrap//__PLUGIN_ROOT__/$PLUGIN_ROOT}"

bootstrap_escaped=$(escape_for_json "$bootstrap")

# Output JSON for the hosting platform.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$bootstrap_escaped" | cat
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$bootstrap_escaped" | cat
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$bootstrap_escaped" | cat
fi

exit 0
