#!/usr/bin/env bash
# SessionStart hook for SuperProgramming plugin
# Injects a lightweight bootstrap — methodology and project constraints
# live in CLAUDE.md (auto-loaded by Claude Code) and L1 (knowledge base).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# Lightweight bootstrap — ~600 tokens.
# The full methodology lives in:
#   1. Project root CLAUDE.md (auto-loaded by Claude Code)
#   2. L1: agent编程守则.md in the knowledge base
#   3. Individual skill files (loaded via Skill tool on demand)
bootstrap=$(cat <<'BOOTSTRAP'
<EXTREMELY-IMPORTANT>
You are powered by **SuperProgramming** — structured development with a four-level cache knowledge system.

## FIRST: Read CLAUDE.md
If a CLAUDE.md exists in the project root, it contains this project's development constraints,
code patterns, and the SuperProgramming methodology. Read it first.

## Skill Discovery
Use the `Skill` tool with these exact names. **Never read skill files manually.**

| Skill | When |
|-------|------|
| `superprogramming:brainstorming` | Before any coding task |
| `superprogramming:writing-plans` | After design is approved |
| `superprogramming:test-driven-development` | During implementation (rigid) |
| `superprogramming:subagent-driven-development` | ≥2 independent tasks (rigid) |
| `superprogramming:dispatching-parallel-agents` | Parallel scheduling strategy |
| `superprogramming:systematic-debugging` | Bug encountered (rigid) |
| `superprogramming:requesting-code-review` | After TDD, before verification — 8-dimension exhaustive (rigid) |
| `superprogramming:verification-before-completion` | Before claiming "done" (rigid) |
| `superprogramming:closing-the-loop` | After all tasks complete (rigid) |
| `superprogramming:finishing-a-development-branch` | Branch cleanup |
| `superprogramming:using-git-worktrees` | Parallel branch work |

## Hard Gates
- If ANY SuperProgramming skill has ≥1% applicability to what you're doing, you MUST call it.
  This is non-negotiable. "Simple", "quick", "just one line" is not an excuse to skip skills.
- User instructions ALWAYS override skill instructions. The user controls the workflow.
- "I remember this skill" → Skills evolve. Load the current version via the Skill tool.
</EXTREMELY-IMPORTANT>
BOOTSTRAP
)

bootstrap_escaped=$(escape_for_json "$bootstrap")

# Output JSON for the hosting platform.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$bootstrap_escaped" | cat
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$bootstrap_escaped" | cat
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$bootstrap_escaped" | cat
fi

exit 0
